rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allows public read/write access. 
    // This is suitable for prototyping or single-user scenarios without real authentication.
    // For a multi-user app, you must implement user-specific security rules.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
