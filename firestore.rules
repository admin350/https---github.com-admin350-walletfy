rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regla para la colección de usuarios
    match /users/{userId}/{documents=**} {
      // Permite a un usuario autenticado leer y escribir en todos los documentos y subcolecciones
      // que le pertenecen.
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Reglas para colecciones públicas de configuración
    // Cualquiera puede leer estas colecciones, ya que son necesarias para el funcionamiento de la UI.
    // Nadie, excepto a través de lógica de backend segura (no aplica aquí), debería poder escribirlas.
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false; // Prohíbe la escritura desde el cliente
    }
    
    match /profiles/{profileId} {
      allow read: if true;
      allow write: if false; // Prohíbe la escritura desde el cliente
    }
  }
}