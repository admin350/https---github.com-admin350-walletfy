rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Un usuario solo puede leer y escribir en su propia colección de documentos.
    // Esto protege todas las subcolecciones como 'profiles', 'categories', 'transactions', etc.
    // de forma automática y escalable.
    match /users/{userId}/{documents=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}