rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Regla para el documento principal del usuario
    match /users/{userId} {
      // Permite a un usuario crear, leer, actualizar y borrar su propio documento ancla.
      allow create, read, update, delete: if request.auth != null && request.auth.uid == userId;

      // Regla para la subcolección 'profiles'
      match /profiles/{profileId} {
        allow read, write, create, delete: if request.auth != null && request.auth.uid == userId;
      }

      // Regla para la subcolección 'categories'
      match /categories/{categoryId} {
        allow read, write, create, delete: if request.auth != null && request.auth.uid == userId;
      }

      // Regla para la subcolección 'settings'
      match /settings/{settingsId} {
        allow read, write, create, delete: if request.auth != null && request.auth.uid == userId;
      }

      // Regla para TODAS las demás subcolecciones (transactions, goals, etc.)
      match /{document=**} {
        allow read, write, create, delete: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}